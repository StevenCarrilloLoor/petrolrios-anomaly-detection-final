# Copie este archivo a .env y rellene los valores. NUNCA suba el .env real al repo.
# Genere secretos robustos, p. ej.:  openssl rand -base64 36

# ===== Base de datos central (PostgreSQL) =====
POSTGRES_DB=petrolrios
POSTGRES_USER=petrolrios
# OBLIGATORIO: contraseña robusta de la base (cámbiela).
POSTGRES_PASSWORD=
# Puerto en el host (solo docker-compose.db.yml). Cámbielo si 5432 está ocupado.
POSTGRES_PORT=5432

# ===== Sistema central =====
# Puerto en el host por el que se accede al panel/API.
CENTRAL_PORT=8080
# OBLIGATORIO: clave JWT robusta, mínimo 32 caracteres (no use la de desarrollo).
JWT_SECRET=
# URL pública con la que se accede al sistema. Se usa para CORS y, sobre todo, para los ENLACES
# dentro de los correos (recuperación, verificación, desbloqueo). Para que esos enlaces sirvan a
# OTROS usuarios, ponga la IP o dominio real, p. ej. http://192.168.1.50:8080 (no "localhost").
FRONTEND_URL=http://localhost:8080

# ===== Cuenta inicial de Administrador =====
# IMPORTANTE: la contraseña del admin vive en la BASE, no aquí.
#  - Si conecta a una base que YA tiene datos, conserva la contraseña que ya tenía.
#  - En una base NUEVA/vacía: si deja esto vacío, el admin arranca como "Admin123!" y el
#    sistema OBLIGA a cambiarla en el primer ingreso.
#  - Si pone un valor aquí, se usa como contraseña inicial Y se obliga a cambiarla. OJO:
#    mientras tenga valor, se REAPLICA en cada arranque (úselo solo para recuperar acceso
#    y luego déjelo vacío).
ADMIN_PASSWORD_INICIAL=

# ===== Correo (SMTP) — avisos, recuperación y verificación de cuenta =====
# Esta config NO está en la base: hay que ponerla aquí (o en appsettings.Secrets.json) en
# cada despliegue. Use las MISMAS credenciales que ya configuró (su app password de correo).
EMAIL_HABILITADO=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PUERTO=587
EMAIL_SSL=true
EMAIL_USUARIO=tu_correo@gmail.com
# La contraseña de aplicación del correo (no la contraseña normal de la cuenta).
EMAIL_PASSWORD=
EMAIL_REMITENTE=alertas@petrolrios.com

# ===== Solo para docker-compose.central.yml (la base vive en otra máquina o la nube) =====
# Cadena de conexión completa Npgsql a la base central:
DB_CONNECTION=Host=IP_DE_LA_BASE;Port=5432;Database=petrolrios;Username=petrolrios;Password=CAMBIAR;SSL Mode=Prefer
