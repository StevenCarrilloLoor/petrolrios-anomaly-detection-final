# Copie este archivo a .env y rellene los valores. NUNCA suba el .env real al repo.
# Genere secretos robustos, p. ej.:  openssl rand -base64 36

# ===== Base de datos central (PostgreSQL) =====
POSTGRES_DB=petrolrios
POSTGRES_USER=petrolrios
# OBLIGATORIO: contraseña robusta de la base (cámbiela).
POSTGRES_PASSWORD=
# Puerto en el host (solo docker-compose.db.yml). Cámbielo si 5432 está ocupado.
POSTGRES_PORT=5432

# ===== Sistema central =====
# Puerto en el host por el que se accede al panel/API.
CENTRAL_PORT=8080
# OBLIGATORIO: clave JWT robusta, mínimo 32 caracteres (no use la de desarrollo).
JWT_SECRET=
# URL pública con la que se accede al sistema (para CORS si usa otro origen).
FRONTEND_URL=http://localhost:8080

# ===== Solo para docker-compose.central.yml (la base vive en otra máquina o la nube) =====
# Cadena de conexión completa Npgsql a la base central:
DB_CONNECTION=Host=IP_DE_LA_BASE;Port=5432;Database=petrolrios;Username=petrolrios;Password=CAMBIAR;SSL Mode=Prefer
